### Register new user
POST http://127.0.0.1:8000/api/accounts/register/
Content-Type: application/json

{
  "username": "john",
  "email": "john@example.com",
  "first_name": "John",
  "last_name": "Smith",
  "password": "StrongPassword123!",
  "password_confirm": "StrongPassword123!"
}

### Get JWT token
POST http://127.0.0.1:8000/api/token/
Content-Type: application/json

{
  "username": "john",
  "password": "StrongPassword123!"
}

### Current user
GET http://127.0.0.1:8000/api/accounts/me/
Authorization: Bearer

### List room types
GET http://127.0.0.1:8000/api/room-types/

### List rooms
GET http://127.0.0.1:8000/api/rooms/

### Get admin JWT token
POST http://127.0.0.1:8000/api/token/
Content-Type: application/json

{
  "username": "",
  "password": ""
}

### Create room type
POST http://127.0.0.1:8000/api/room-types/
Content-Type: application/json
Authorization: Bearer

{
  "name": "Conference Room",
  "description": "Room type for meetings and team discussions."
}

### Create room
POST http://127.0.0.1:8000/api/rooms/
Content-Type: application/json
Authorization: Bearer

{
  "name": "Room A",
  "room_type": 1,
  "location": "First floor",
  "capacity": 8,
  "description": "Small meeting room with a whiteboard.",
  "is_active": true
}

### List bookings
GET http://127.0.0.1:8000/api/bookings/
Authorization: Bearer

### Create booking
POST http://127.0.0.1:8000/api/bookings/
Content-Type: application/json
Authorization: Bearer

{
  "room": 1,
  "title": "Team meeting 2",
  "description": "Weekly team sync.",
  "start_time": "2026-07-11T10:00:00Z",
  "end_time": "2026-07-11T11:00:00Z"
}

### Cancel booking
POST http://127.0.0.1:8000/api/bookings/2/cancel/
Authorization: Bearer

### Confirm booking
POST http://127.0.0.1:8000/api/bookings/2/confirm/
Authorization: Bearer

### Complete booking
POST http://127.0.0.1:8000/api/bookings/1/complete/
Authorization: Bearer